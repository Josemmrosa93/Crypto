# BLOQUE 6 -- FILL LISTENER (WEBSOCKET TIEMPO REAL)
# =============================================================================

class FillListener:
    """
    Escucha ejecuciones de ordenes en tiempo real via WebSocket privado.
    Cuando detecta un fill llama a grid.handle_fill_realtime() inmediatamente.
    Se reconecta automaticamente si cae la conexion.
    """
    WS_URL = "wss://stream.crypto.com/exchange/v1/user"

    def __init__(self, api_key, api_secret, symbol, grid):
        self.api_key    = api_key
        self.api_secret = api_secret
        self.symbol     = symbol
        self.grid       = grid
        self._ws        = None
        self._authed    = False
        self._active    = True

    def _sign(self, req_id, nonce):
        payload = f"public/auth{req_id}{self.api_key}{nonce}"
        return hmac.new(
            self.api_secret.encode(), payload.encode(), hashlib.sha256
        ).hexdigest()

    def _send(self, msg):
        try:
            if self._ws:
                self._ws.send(json.dumps(msg))
        except Exception:
            pass

    def _on_open(self, _ws):
        self._authed = False
        nonce  = int(time.time() * 1000)
        req_id = nonce % 2_000_000_000
        self._send({
            "id":      req_id,
            "method":  "public/auth",
            "api_key": self.api_key,
            "nonce":   nonce,
            "sig":     self._sign(req_id, nonce),
        })

    def _on_message(self, ws, message):
        try:
            data = json.loads(message)
        except Exception:
            return

        method = data.get("method", "")

        if method == "public/heartbeat":
            self._send({"id": data["id"], "method": "public/respond-heartbeat"})
            return

        # Respuesta al auth -> suscribirse
        if not self._authed and data.get("code") == 0 and data.get("id"):
            self._authed = True
            self._send({
                "id":     1,
                "method": "subscribe",
                "params": {"channels": [f"user.order.{self.symbol}"]},
            })
            log.info("[WS] Suscrito a fills de %s", self.symbol)
            return

        # Evento de fill
        if method == "subscribe":
            for order in data.get("result", {}).get("data", []):
                if order.get("status") in ("FILLED", "PARTIALLY_FILLED"):
                    self.grid.handle_fill_realtime(
                        order.get("order_id", ""),
                        order.get("side", ""),
                        float(order.get("price", 0)),
                        float(order.get("cumulative_quantity", order.get("quantity", 0))),
                    )

    def _on_error(self, ws, error):
        log.warning("[WS] Error: %s", error)

    def _on_close(self, ws, *args):
        if self._active:
            log.warning("[WS] Conexion cerrada -- reconectando en 5s...")
            time.sleep(5)
            self._connect()

    def _connect(self):
        import websocket as _wslib
        self._ws = _wslib.WebSocketApp(
            self.WS_URL,
            on_open=self._on_open,
            on_message=self._on_message,
            on_error=self._on_error,
            on_close=self._on_close,
        )
        t = threading.Thread(target=self._ws.run_forever, daemon=True)
        t.start()

    def start(self):
        self._active = True
        self._connect()
        log.info("[WS] FillListener iniciado")

    def stop(self):
        self._active = False
        if self._ws:
            self._ws.close()


