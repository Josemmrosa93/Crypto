import requests


class CryptoComClient:
    """
    Wrapper sobre la API REST v1 de Crypto.com Exchange.

    Metodos principales:
      get_mid_price()      -> (bid+ask)/2 en tiempo real
      get_order_book()     -> niveles bid/ask del libro
      estimate_slippage()  -> impacto estimado de una orden MARKET en el libro
      get_fee_rate()       -> fees reales del usuario desde la API
    """

    def __init__(self, api_key, api_secret, base_url):
        self.api_key    = api_key
        self.api_secret = api_secret
        self.base_url   = base_url
        self.session    = requests.Session()
        self.session.headers.update({"Content-Type": "application/json"})

    # -- Firma HMAC-SHA256 ----------------------------------------------------
    def _sign(self, method, req_id, params, nonce):
        param_str = "".join(f"{k}{v}" for k, v in sorted(params.items()))
        payload   = f"{method}{req_id}{self.api_key}{param_str}{nonce}"
        return hmac.new(
            self.api_secret.encode(), payload.encode(), hashlib.sha256
        ).hexdigest()

    def _private(self, method, params=None):
        params = params or {}
        nonce  = int(time.time() * 1000)
        req_id = nonce % 2_000_000_000
        body   = {
            "id":      req_id,
            "method":  method,
            "api_key": self.api_key,
            "params":  params,
            "nonce":   nonce,
            "sig":     self._sign(method, req_id, params, nonce),
        }
        url  = f"{self.base_url}/private/{method.split('/')[-1]}"
        resp = self.session.post(url, json=body, timeout=10)
        if not resp.ok:
            log.error("[FAIL] %s -> %s | body: %s", method, resp.status_code, resp.text[:500])
        resp.raise_for_status()
        data = resp.json()
        if data.get("code") != 0:
            raise RuntimeError(f"API {data.get('code')}: {data.get('message')}")
        return data.get("result", {})

    def _public(self, endpoint, params=None):
        url  = f"{self.base_url}/public/{endpoint}"
        resp = self.session.get(url, params=params, timeout=10)
        resp.raise_for_status()
        data = resp.json()
        if data.get("code") != 0:
            raise RuntimeError(f"API {data.get('code')}: {data.get('message')}")
        return data.get("result", {})

    # -- Mercado --------------------------------------------------------------
    def get_candlesticks(self, symbol, timeframe, count=100):
        return self._public("get-candlestick", {
            "instrument_name": symbol,
            "timeframe":       timeframe,
            "count":           count,
        }).get("data", [])

    def get_ticker(self, symbol):
        """Ticker completo: bid (b), ask (a), last (k), vol 24h (v)."""
        return self._public(
            "get-tickers", {"instrument_name": symbol}
        ).get("data", [{}])[0]

    def get_mid_price(self, symbol):
        """
        Precio mid real = (mejor_bid + mejor_ask) / 2.
        Devuelve (mid, bid, ask).
        Mas preciso que el cierre de la ultima vela.
        """
        ticker = self.get_ticker(symbol)
        bid    = float(ticker.get("b", 0) or 0)
        ask    = float(ticker.get("a", 0) or 0)
        if bid <= 0 or ask <= 0:
            last = float(ticker.get("k", 0) or 0)
            return last, last, last
        mid = (bid + ask) / 2
        return round(mid, 2), round(bid, 2), round(ask, 2)

    def get_order_book(self, symbol, depth=10):
        """
        Libro de ordenes con `depth` niveles.
        Devuelve {"bids": [[price, qty], ...], "asks": [[price, qty], ...]}
        """
        raw  = self._public("get-book", {
            "instrument_name": symbol,
            "depth":           depth,
        })
        bids = [[float(x[0]), float(x[1])] for x in raw.get("bids", [])]
        asks = [[float(x[0]), float(x[1])] for x in raw.get("asks", [])]
        return {"bids": bids, "asks": asks}

    def estimate_slippage(self, symbol, side, usdt_amount, max_slip_pct):
        """
        Simula el impacto de una orden MARKET en el libro real.
        - BUY  -> consume asks de menor a mayor precio
        - SELL -> consume bids de mayor a menor precio
        Devuelve (precio_medio_ejecucion, slippage_pct, es_aceptable).
        """
        book       = self.get_order_book(symbol, depth=CONFIG["book_depth"])
        levels     = book["asks"] if side == "BUY" else book["bids"]
        best_price = levels[0][0] if levels else 0

        if not levels or best_price == 0:
            log.warning("[WARN] [BOOK] Libro vacio, no se puede estimar slippage")
            return best_price, 0.0, True

        remaining = usdt_amount
        total_qty  = 0.0
        total_cost = 0.0

        for price, qty in levels:
            level_usdt = price * qty
            if level_usdt >= remaining:
                fill        = remaining / price
                total_qty  += fill
                total_cost += fill * price
                remaining   = 0
                break
            else:
                total_qty  += qty
                total_cost += qty * price
                remaining  -= level_usdt

        if remaining > 0:
            pct = (usdt_amount - remaining) / usdt_amount * 100
            log.warning(
                "[WARN] [BOOK] Liquidez insuficiente. Solo se cubriria el %.1f%% de la orden",
                pct,
            )
            return best_price, 0.0, False

        avg   = total_cost / total_qty if total_qty > 0 else best_price
        slip  = abs(avg - best_price) / best_price
        is_ok = slip <= max_slip_pct

        log.info(
            "[BOOK] [%s] %.0f USDT | Top=%.2f | Ejecucion~%.2f | Slippage=%.3f%% [%s]",
            side, usdt_amount, best_price, avg, slip * 100,
            "OK" if is_ok else "EXCEDE LIMITE",
        )
        return round(avg, 2), round(slip, 6), is_ok

    # -- Cuenta ---------------------------------------------------------------
    def get_fee_rate(self, symbol):
        """
        Fees reales del usuario desde private/get-fee-rate.
        Devuelve {"maker": float, "taker": float} en decimal, o None si falla.
        Las fees varian segun volumen 30d y staking de CRO.
        """
        try:
            result    = self._private("private/get-fee-rate", {
                "instrument_name": symbol,
            })
            maker_str = result.get("maker_rate", result.get("maker", "0.050"))
            taker_str = result.get("taker_rate", result.get("taker", "0.075"))
            maker     = float(maker_str) / 100
            taker     = float(taker_str) / 100
            log.info(
                "[OK] Fees reales de la API -> Maker: %.4f%%  Taker: %.4f%%",
                maker * 100, taker * 100,
            )
            return {"maker": maker, "taker": taker}
        except Exception as exc:
            log.warning(
                "[WARN] No se pudieron obtener fees de la API (%s). Usando CONFIG.", exc
            )
            return None

    def get_balance(self, currency="USDT"):
        result = self._private("private/user-balance", {})
        positions = result.get("data", [{}])[0].get("position_balances", [])
        for pos in positions:
            if pos.get("instrument_name") == currency:
                return float(pos.get("quantity", 0))
        return 0.0

    def get_open_orders(self, symbol):
        result = self._private("private/get-open-orders", {
            "instrument_name": symbol,
            "page_size":       50,
        })
        return result.get("data", result.get("order_list", []))

    # -- Ordenes --------------------------------------------------------------
    def place_order(self, symbol, side, order_type, quantity,
                    price=None, client_oid=None):
        params = {
            "instrument_name": symbol,
            "side":            side,
            "type":            order_type,
            "quantity":        f"{math.floor(quantity * 100000) / 100000:.5f}",
        }
        if price and order_type == "LIMIT":
            params["price"] = f"{price:.2f}"
        if client_oid:
            params["client_oid"] = client_oid
        return self._private("private/create-order", params)

    def cancel_order(self, symbol, order_id):
        return self._private("private/cancel-order", {
            "instrument_name": symbol,
            "order_id":        order_id,
        })

    def cancel_all_orders(self, symbol):
        return self._private("private/cancel-all-orders", {
            "instrument_name": symbol,
        })


# -- Calculadora de costes ----------------------------------------------------
class FeeCalculator:
    """
    Calcula costes reales de cada operacion:
      - Comision maker (LIMIT) o taker (MARKET)
      - Slippage estimado del order book
      - PnL neto tras todos los costes

    Al iniciarse consulta las fees reales de la API.
    Si falla, usa los valores del CONFIG como fallback.
    """

    def __init__(self, cfg, api_client=None):
        real_fees = api_client.get_fee_rate(cfg["symbol"]) if api_client else None

        if real_fees:
            self.fee_maker = real_fees["maker"]
            self.fee_taker = real_fees["taker"]
            self.source    = "API"
        else:
            self.fee_maker = cfg["fee_maker"]
            self.fee_taker = cfg["fee_taker"]
            self.source    = "CONFIG (fallback)"

        log.info(
            "[FEE] FeeCalculator [%s] -> Maker=%.4f%%  Taker=%.4f%%",
            self.source, self.fee_maker * 100, self.fee_taker * 100,
        )

    def fee_rate(self, order_type):
        return self.fee_maker if order_type == "LIMIT" else self.fee_taker

    def calc_entry_cost(self, usdt_amount, exec_price, order_type, slippage_pct=0.0):
        """
        Coste de ENTRADA.
        Devuelve dict: qty, fee_usdt, slippage_usdt, total_cost,
                       effective_price, fee_rate, fee_type.
        """
        rate  = self.fee_rate(order_type)
        eff   = exec_price * (1 + slippage_pct) if order_type == "MARKET" else exec_price
        qty   = usdt_amount / eff
        fee   = usdt_amount * rate
        slip  = usdt_amount * slippage_pct if order_type == "MARKET" else 0.0
        return {
            "qty":             round(qty, 8),
            "fee_usdt":        round(fee, 6),
            "slippage_usdt":   round(slip, 6),
            "total_cost":      round(usdt_amount + fee, 6),
            "effective_price": round(eff, 2),
            "fee_rate":        rate,
            "fee_type":        "maker" if order_type == "LIMIT" else "taker",
        }

    def calc_exit_cost(self, qty, exec_price, order_type, slippage_pct=0.0):
        """
        Coste de SALIDA.
        Devuelve dict: gross_usdt, fee_usdt, slippage_usdt, net_usdt,
                       effective_price, fee_rate, fee_type.
        """
        rate  = self.fee_rate(order_type)
        eff   = exec_price * (1 - slippage_pct) if order_type == "MARKET" else exec_price
        gross = qty * eff
        fee   = gross * rate
        slip  = qty * exec_price * slippage_pct if order_type == "MARKET" else 0.0
        return {
            "gross_usdt":      round(gross, 6),
            "fee_usdt":        round(fee, 6),
            "slippage_usdt":   round(slip, 6),
            "net_usdt":        round(gross - fee, 6),
            "effective_price": round(eff, 2),
            "fee_rate":        rate,
            "fee_type":        "maker" if order_type == "LIMIT" else "taker",
        }

    def min_move_to_profit(self, order_type_entry, order_type_exit):
        """Movimiento minimo (%) para cubrir fees de entrada y salida."""
        return round((self.fee_rate(order_type_entry) + self.fee_rate(order_type_exit)) * 100, 4)

    def log_summary(self, direction, entry, exit_info=None):
        log.info(
            "[FEE] Entrada [%s] %.3f%% = %.4f USDT | Slippage = %.4f USDT | Precio eff = %.2f",
            entry["fee_type"], entry["fee_rate"] * 100,
            entry["fee_usdt"], entry["slippage_usdt"], entry["effective_price"],
        )
        if exit_info:
            log.info(
                "[FEE] Salida  [%s] %.3f%% = %.4f USDT | Neto recibido = %.4f USDT",
                exit_info["fee_type"], exit_info["fee_rate"] * 100,
                exit_info["fee_usdt"], exit_info["net_usdt"],
            )


