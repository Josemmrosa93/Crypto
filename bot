class GridEngine:
    """
    Grid Trading con ordenes LIMIT (fee maker).

    - Construye N niveles equidistantes en rango +/- X% alrededor del mid.
    - Verifica que el paso entre niveles supera el breakeven de comisiones.
    - Cuando se ejecuta una orden, coloca la contraria en el nivel adyacente.
    - SL global si el mid cae por debajo de grid_low * (1 - grid_sl_pct).
    - Todo el PnL registrado es NETO (descontando fees maker de entrada y salida).
    """

    def __init__(self, cfg, api_client, fee_calc):
        self.cfg             = cfg
        self.client          = api_client
        self.fees            = fee_calc
        self.active          = False
        self.levels          = []
        self.orders          = {}   # {order_id: {level, side, qty, fee_usdt}}
        self.center          = None
        self.grid_low        = None
        self.grid_high       = None
        self.sl_price        = None
        self.realized_pnl    = 0.0
        self.total_fees_paid = 0.0
        self._lock           = threading.Lock()

    def setup(self, center_price):
        breakeven = 2 * self.fees.fee_maker
        step_pct  = breakeven * self.cfg["grid_margin_mult"]
        step      = round(center_price * step_pct, 2)
        n         = self.cfg["grid_levels"]
        margin_pct = step_pct - breakeven

        self.center    = center_price
        self.grid_low  = round(center_price - step * (n // 2), 2)
        self.grid_high = round(center_price + step * (n // 2), 2)
        self.sl_price  = round(self.grid_low * (1 - self.cfg["grid_sl_pct"]), 2)
        self.levels    = [round(center_price + step * i, 2)
                          for i in range(-(n // 2), n // 2 + 1)]
        self.levels    = sorted(set(self.levels))[:n]

        log.info(
            "[GRID] Configurado: [%.2f -- %.2f] | Centro=%.2f | "
            "Paso=%.2f (%.3f%%) | Margen neto=%.3f%% | SL=%.2f",
            self.grid_low, self.grid_high, center_price,
            step, step_pct * 100, margin_pct * 100, self.sl_price,
        )
        return True

    def place_initial_orders(self, mid_price):
        """Coloca ordenes LIMIT en todos los niveles segun el mid real."""
        symbol       = self.cfg["symbol"]
        order_usd    = self.cfg["grid_order_usdt"]
        base_ccy     = symbol.split("_")[0]
        btc_avail    = self.client.get_balance(base_ccy)

        for level in self.levels:
            if abs(level - mid_price) / mid_price < 0.001:
                continue
            side  = "BUY" if level < mid_price else "SELL"
            costs = self.fees.calc_entry_cost(order_usd, level, "LIMIT")

            if side == "SELL":
                if btc_avail < costs["qty"] * 0.999:
                    log.info("[GRID] SELL @ %.2f omitida -- sin %s disponible", level, base_ccy)
                    continue
                sell_qty   = min(costs["qty"], btc_avail)
                btc_avail -= sell_qty  # reservar para la siguiente SELL
            else:
                sell_qty = costs["qty"]

            try:
                result = self.client.place_order(
                    symbol, side, "LIMIT", sell_qty, price=level,
                    client_oid=f"grid_{side}_{int(level)}_{int(time.time())}",
                )
                oid = result.get("order_id", "")
                self.orders[oid] = {
                    "level":    level,
                    "side":     side,
                    "qty":      sell_qty,
                    "fee_usdt": costs["fee_usdt"],
                }
                log.info(
                    "[ORDER] %s LIMIT @ %.2f | Qty=%.6f | Fee=%.4f EUR [maker]",
                    side, level, sell_qty, costs["fee_usdt"],
                )
            except Exception as exc:
                log.info("[GRID] %s @ %.2f omitida -- %s", side, level, exc)

        self.active = True

    def _place_counter_order(self, symbol, order, next_level, next_side, order_usd):
        """Coloca la orden contraria tras un fill. Devuelve True si tuvo exito."""
        base_ccy   = symbol.split("_")[0]
        next_costs = self.fees.calc_entry_cost(order_usd, next_level, "LIMIT")
        sell_qty   = next_costs["qty"]
        if next_side == "SELL":
            avail = self.client.get_balance(base_ccy)
            if avail <= 0:
                log.info("[GRID] SELL @ %.2f omitida -- sin %s", next_level, base_ccy)
                return False
            sell_qty = min(sell_qty, avail)
        try:
            result = self.client.place_order(
                symbol, next_side, "LIMIT", sell_qty, price=next_level,
                client_oid=f"grid_{next_side}_{int(next_level)}_{int(time.time())}",
            )
            new_id = result.get("order_id", "")
            self.orders[new_id] = {
                "level":    next_level,
                "side":     next_side,
                "qty":      sell_qty,
                "fee_entry": next_costs["fee_usdt"],
                "fee_usdt": next_costs["fee_usdt"],
                "pair_entry_level": order["level"],
                "pair_entry_side":  order["side"],
                "pair_entry_qty":   order["qty"],
                "pair_entry_fee":   order.get("fee_entry", order["fee_usdt"]),
            }
            log.info("[ORDER] %s LIMIT @ %.2f [contraria]", next_side, next_level)
            return True
        except Exception as exc:
            log.error("[FAIL] Orden contraria @ %.2f: %s", next_level, exc)
            return False

    def _calc_pnl(self, order):
        """Calcula PnL neto cuando se cierra un ciclo completo BUY+SELL."""
        if "pair_entry_level" not in order:
            return None
        entry_level = order["pair_entry_level"]
        exit_level  = order["level"]
        qty         = order["pair_entry_qty"]
        fee_in      = order["pair_entry_fee"]
        fee_out     = order.get("fee_entry", order["fee_usdt"])
        pnl         = (exit_level - entry_level) * qty - fee_in - fee_out
        return round(pnl, 6)

    def refresh(self, mid_price, open_order_ids):
        """Detecta ordenes ejecutadas por polling (fallback al WS)."""
        if not self.active:
            return
        symbol    = self.cfg["symbol"]
        order_usd = self.cfg["grid_order_usdt"]
        executed  = {oid: o for oid, o in list(self.orders.items())
                     if oid not in open_order_ids}

        for oid, order in executed.items():
            if oid not in self.orders:
                continue  # ya procesado por WS
            level = order["level"]
            side  = order["side"]
            try:
                idx = self.levels.index(level)
            except ValueError:
                del self.orders[oid]
                continue

            if side == "BUY" and idx + 1 < len(self.levels):
                next_level, next_side = self.levels[idx + 1], "SELL"
            elif side == "SELL" and idx - 1 >= 0:
                next_level, next_side = self.levels[idx - 1], "BUY"
            else:
                del self.orders[oid]
                continue

            # PnL solo al cerrar ciclo completo: SELL ejecutada con par de BUY
            if side == "SELL" and "pair_entry_level" in order:
                pnl = self._calc_pnl(order)
                if pnl is not None:
                    self.realized_pnl    += pnl
                    self.total_fees_paid += order["pair_entry_fee"] + order.get("fee_entry", order["fee_usdt"])
                    log.info("[OK] [GRID] Ciclo BUY@%.2f->SELL@%.2f | PnL=%+.4f EUR | Acumulado=%+.4f EUR",
                             order["pair_entry_level"], level, pnl, self.realized_pnl)

            self._place_counter_order(symbol, order, next_level, next_side, order_usd)
            del self.orders[oid]

    def handle_fill_realtime(self, order_id, side, _price, _qty):
        """Callback del WebSocket: reacciona a un fill inmediatamente."""
        with self._lock:
            order = self.orders.get(order_id)
            if not order or not self.active:
                return
            level     = order["level"]
            symbol    = self.cfg["symbol"]
            order_usd = self.cfg["grid_order_usdt"]
            try:
                idx = self.levels.index(level)
            except ValueError:
                del self.orders[order_id]
                return

            if side == "BUY" and idx + 1 < len(self.levels):
                next_level, next_side = self.levels[idx + 1], "SELL"
            elif side == "SELL" and idx - 1 >= 0:
                next_level, next_side = self.levels[idx - 1], "BUY"
            else:
                del self.orders[order_id]
                return

            # PnL solo al cerrar ciclo completo: SELL con par de BUY registrado
            if side == "SELL" and "pair_entry_level" in order:
                pnl = self._calc_pnl(order)
                if pnl is not None:
                    self.realized_pnl    += pnl
                    self.total_fees_paid += order["pair_entry_fee"] + order.get("fee_entry", order["fee_usdt"])
                    log.info("[WS] [OK] Ciclo BUY@%.2f->SELL@%.2f | PnL=%+.4f EUR | Acumulado=%+.4f EUR",
                             order["pair_entry_level"], level, pnl, self.realized_pnl)
            else:
                log.info("[WS] Fill %s @ %.2f detectado", side, level)

            if next_side == "SELL":
                time.sleep(0.5)  # esperar liquidacion del fill en la cuenta
            self._place_counter_order(symbol, order, next_level, next_side, order_usd)
            del self.orders[order_id]

    def check_sl(self, mid_price):
        """SL global del grid evaluado sobre el mid real del ticker."""
        if self.sl_price and mid_price < self.sl_price:
            log.warning(
                "[STOP] [GRID] SL activado | Mid=%.2f < SL=%.2f | "
                "PnL realizado=%+.4f USDT | Fees=%.4f USDT",
                mid_price, self.sl_price, self.realized_pnl, self.total_fees_paid,
            )
            return True
        return False

    def close(self):
        try:
            self.client.cancel_all_orders(self.cfg["symbol"])
        except Exception as exc:
            log.error("[FAIL] Cancelando ordenes grid: %s", exc)
        log.info(
            "[CLOSE] [GRID] Cerrado | PnL neto=%+.4f USDT | Fees=%.4f USDT",
            self.realized_pnl, self.total_fees_paid,
        )
        self.orders          = {}
        self.active          = False
        self.realized_pnl    = 0.0
        self.total_fees_paid = 0.0


