# BLOQUE 3 -- DETECTOR DE REGIMEN (ADX + BBW)
# =============================================================================

import pandas as pd
import numpy as np

REGIME_LATERAL  = "LATERAL"
REGIME_TREND_UP = "TREND_UP"
REGIME_TREND_DN = "TREND_DOWN"
REGIME_BREAKOUT = "BREAKOUT"


class RegimeDetector:
    """
    Clasifica el mercado combinando ADX y Bollinger Band Width.

    LATERAL:   ADX < 25 Y BBW < 3%
    TENDENCIA: ADX > 30 O BBW > 6%
    BREAKOUT:  mid_price fuera del rango del grid activo + volumen elevado

    El regimen se suaviza con un historial de N velas para evitar ruido.
    """

    def __init__(self, cfg):
        self.cfg       = cfg
        self._history  = []
        self.grid_high = None
        self.grid_low  = None

    def build_df(self, candles):
        df = pd.DataFrame(candles, columns=["t", "o", "h", "l", "c", "v"])
        for col in ["o", "h", "l", "c", "v"]:
            df[col] = pd.to_numeric(df[col])
        df["t"] = pd.to_numeric(df["t"])
        return df.sort_values("t").reset_index(drop=True)

    def _adx(self, df, period):
        high, low, close = df["h"], df["l"], df["c"]
        tr = pd.concat([
            high - low,
            (high - close.shift()).abs(),
            (low  - close.shift()).abs(),
        ], axis=1).max(axis=1)
        dm_pos = (high - high.shift()).clip(lower=0)
        dm_neg = (low.shift() - low).clip(lower=0)
        dm_pos = dm_pos.where(dm_pos > dm_neg, 0)
        dm_neg = dm_neg.where(dm_neg > dm_pos, 0)
        atr    = tr.ewm(span=period, adjust=False).mean()
        di_pos = 100 * dm_pos.ewm(span=period, adjust=False).mean() / atr
        di_neg = 100 * dm_neg.ewm(span=period, adjust=False).mean() / atr
        dx     = 100 * (di_pos - di_neg).abs() / (di_pos + di_neg).replace(0, np.nan)
        return dx.ewm(span=period, adjust=False).mean(), di_pos, di_neg

    def _bbw(self, df, period, std_mult):
        sma   = df["c"].rolling(period).mean()
        std   = df["c"].rolling(period).std()
        upper = sma + std_mult * std
        lower = sma - std_mult * std
        return (upper - lower) / sma, upper, lower

    def detect(self, df, mid_price):
        """
        Devuelve (regime_final, adx_val, bbw_val).
        Usa mid_price real del ticker para detectar breakouts.
        """
        adx, di_pos, di_neg = self._adx(df, self.cfg["adx_period"])
        bbw, _, _            = self._bbw(df, self.cfg["bbw_period"], self.cfg["bbw_std"])
        vol_mean             = df["v"].rolling(20).mean()

        adx_val = adx.iloc[-1]
        bbw_val = bbw.iloc[-1]
        cur_vol = df["v"].iloc[-1]

        adx_lateral  = adx_val < self.cfg["adx_lateral_th"]
        adx_trending = adx_val > self.cfg["adx_trend_th"]
        bbw_squeeze  = bbw_val < self.cfg["bbw_squeeze_th"]
        bbw_expand   = bbw_val > self.cfg["bbw_expand_th"]
        vol_spike    = cur_vol > vol_mean.iloc[-1] * self.cfg["breakout_volume_mult"]
        trend_up     = di_pos.iloc[-1] > di_neg.iloc[-1]

        # Breakout: precio mid fuera del rango del grid activo
        breakout = False
        if self.grid_high and self.grid_low:
            outside = mid_price > self.grid_high or mid_price < self.grid_low
            if outside and vol_spike:
                n       = self.cfg["breakout_confirm_candles"]
                recent  = df["c"].iloc[-n:]
                all_out = all(c > self.grid_high or c < self.grid_low for c in recent)
                breakout = all_out

        if breakout:
            regime = REGIME_BREAKOUT
        elif adx_trending and bbw_expand:
            regime = REGIME_TREND_UP if trend_up else REGIME_TREND_DN
        elif adx_lateral and bbw_squeeze:
            regime = REGIME_LATERAL
        else:
            regime = self._history[-1] if self._history else REGIME_LATERAL

        self._history.append(regime)
        if len(self._history) > self.cfg["regime_lookback"]:
            self._history.pop(0)

        from collections import Counter
        regime_final = Counter(self._history).most_common(1)[0][0]

        log.info(
            "[REGIME] %-12s | ADX=%.1f | BBW=%.2f%% | Mid=%.2f",
            regime_final, adx_val, bbw_val * 100, mid_price,
        )
        return regime_final, adx_val, bbw_val


