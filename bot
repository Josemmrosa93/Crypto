# BLOQUE 7 -- ORQUESTADOR PRINCIPAL (BUCLE ADAPTATIVO)
# =============================================================================

class AdaptiveGridBot:
    """
    Coordina los bloques anteriores en un bucle continuo.

    Cada ciclo:
      1. Obtiene mid/bid/ask del ticker en tiempo real
      2. Descarga candlesticks y detecta el regimen (ADX + BBW)
      3. Si LATERAL  -> mantiene o activa el grid
      4. Si TENDENCIA/BREAKOUT -> opera con RSI+EMA+MACD o direccion directa
      5. Gestiona transiciones limpias entre modos
      6. Cierre limpio al parar (Ctrl+C)
    """

    def __init__(self, cfg, api_client, detector, grid, trend):
        self.cfg      = cfg
        self.client   = api_client
        self.detector = detector
        self.grid     = grid
        self.trend    = trend
        self.symbol   = cfg["symbol"]
        self.interval = TIMEFRAME_SECONDS.get(cfg["timeframe"], 300)
        self.regime   = None
        self.running  = False
        self.fill_listener = FillListener(
            API_KEY, API_SECRET, self.symbol, self.grid
        )

    def _switch_to_lateral(self, mid, bid, ask):
        if self.trend.position:
            log.info("[SWITCH] TREND -> LATERAL | Cerrando posicion...")
            self.trend.close(mid, bid, ask, reason="REGIME_CHANGE")
        if not self.grid.active:
            ok = self.grid.setup(mid)
            if ok:
                self.detector.grid_high = self.grid.grid_high
                self.detector.grid_low  = self.grid.grid_low
                self.grid.place_initial_orders(mid)

    def _switch_to_trend(self, new_regime):
        if self.grid.active:
            log.info("[SWITCH] LATERAL -> %s | Cerrando grid...", new_regime)
            self.grid.close()
            self.detector.grid_high = None
            self.detector.grid_low  = None

    def run(self):
        log.info(
            "[BOT] Adaptive Grid Bot v3 | %s | %s | "
            "Precio referencia: mid=(bid+ask)/2 en tiempo real",
            self.symbol, self.cfg["timeframe"],
        )
        self.running = True
        self.fill_listener.start()

        while self.running:
            try:
                log.info("-" * 65)

                # 1. Precio mid real del ticker
                mid, bid, ask = self.client.get_mid_price(self.symbol)
                spread_pct    = (ask - bid) / mid * 100 if mid > 0 else 0
                log.info(
                    "[PRICE] Mid=%.2f | Bid=%.2f | Ask=%.2f | Spread=%.4f%%",
                    mid, bid, ask, spread_pct,
                )
                if spread_pct > 0.05:
                    log.warning(
                        "[WARN] Spread elevado (%.4f%%) -- liquidez baja", spread_pct
                    )

                # 2. Candlesticks + deteccion de regimen
                candles    = self.client.get_candlesticks(
                    self.symbol, self.cfg["timeframe"], count=100
                )
                df         = self.detector.build_df(candles)
                new_regime, adx, bbw = self.detector.detect(df, mid)

                # 3. Gestionar regimen
                if new_regime == REGIME_LATERAL:
                    if self.regime != REGIME_LATERAL:
                        self._switch_to_lateral(mid, bid, ask)
                    elif self.grid.active:
                        open_ids = {
                            o["order_id"]
                            for o in self.client.get_open_orders(self.symbol)
                        }
                        # Reconstruir si no hay ordenes (canceladas externamente o todas ejecutadas)
                        if not open_ids and not self.grid.orders:
                            log.info("[GRID] Grid vacio -- reconstruyendo...")
                            self.grid.active = False
                            self._switch_to_lateral(mid, bid, ask)
                        else:
                            self.grid.refresh(mid, open_ids)
                        if self.grid.check_sl(mid):
                            self.grid.close()
                            self.detector.grid_high = None
                            self.detector.grid_low  = None
                        else:
                            log.info(
                                "[GRID] [%.0f -- %.0f] | Ordenes=%d | "
                                "PnL neto=%+.4f USDT | Fees=%.4f USDT",
                                self.grid.grid_low, self.grid.grid_high,
                                len(self.grid.orders),
                                self.grid.realized_pnl,
                                self.grid.total_fees_paid,
                            )

                elif new_regime in (REGIME_TREND_UP, REGIME_TREND_DN, REGIME_BREAKOUT):
                    if self.regime == REGIME_LATERAL:
                        self._switch_to_trend(new_regime)

                    # Comprobar SL/TP sobre mid real
                    exit_reason = self.trend.check_exit(mid)
                    if exit_reason:
                        self.trend.close(mid, bid, ask, reason=exit_reason)

                    # Abrir posicion si no hay ninguna
                    if not self.trend.position:
                        balance = self.client.get_balance("EUR")

                        if new_regime == REGIME_BREAKOUT:
                            if self.grid.grid_high and mid > self.grid.grid_high:
                                signal = "BUY"
                            elif self.grid.grid_low and mid < self.grid.grid_low:
                                signal = "SELL"
                            else:
                                signal = "NEUTRAL"
                            log.info("[BREAKOUT] Senal directa: %s", signal)
                        else:
                            signal = self.trend.get_signal(df)

                        if signal in ("BUY", "SELL"):
                            self.trend.open(signal, mid, bid, ask, balance)

                    # PnL no realizado
                    if self.trend.position:
                        pnl = self.trend.unrealized_pnl(mid)
                        log.info(
                            "[PNL] [%s] Entry=%.2f | Mid=%.2f | PnL neto~%+.4f USDT",
                            self.trend.position["side"],
                            self.trend.position["entry"],
                            mid, pnl,
                        )

                self.regime = new_regime

            except KeyboardInterrupt:
                log.info("[STOP] Detenido manualmente -- cerrando posiciones...")
                self.running = False
                self.fill_listener.stop()
                try:
                    mid, bid, ask = self.client.get_mid_price(self.symbol)
                    if self.grid.active:
                        self.grid.close()
                    if self.trend.position:
                        self.trend.close(mid, bid, ask, reason="MANUAL_STOP")
                except Exception:
                    pass
                total_fees = self.grid.total_fees_paid + self.trend.total_fees_paid
                log.info(
                    "[FEE] Fees totales pagadas en esta sesion: %.4f USDT", total_fees
                )
                break
            except Exception as exc:
                log.error("[FAIL] Error inesperado: %s", exc, exc_info=True)

            log.info("[WAIT] Proximo ciclo en %ds...", self.interval)
            time.sleep(self.interval)


