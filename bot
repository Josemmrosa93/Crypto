# BLOQUE 5 -- ESTRATEGIA DE TENDENCIA (RSI + EMA + MACD)
# =============================================================================

class TrendStrategy:
    """
    Seguimiento de tendencia con costes reales.

    Ordenes MARKET -> fee taker (0.075%).
    Antes de abrir, consulta el order book para estimar slippage.
    SL/TP calculados sobre el precio efectivo real (post-slippage).
    PnL neto descuenta fees de entrada y salida.
    """

    def __init__(self, cfg, api_client, fee_calc):
        self.cfg             = cfg
        self.client          = api_client
        self.fees            = fee_calc
        self.position        = None
        self.total_fees_paid = 0.0

    def _indicators(self, df):
        c     = df["c"]
        delta = c.diff()
        gain  = delta.clip(lower=0).rolling(self.cfg["rsi_period"]).mean()
        loss  = (-delta.clip(upper=0)).rolling(self.cfg["rsi_period"]).mean()
        rsi   = 100 - (100 / (1 + gain / loss.replace(0, np.nan)))
        ema_f = c.ewm(span=self.cfg["ema_fast"], adjust=False).mean()
        ema_s = c.ewm(span=self.cfg["ema_slow"], adjust=False).mean()
        fast  = c.ewm(span=self.cfg["macd_fast"], adjust=False).mean()
        slow  = c.ewm(span=self.cfg["macd_slow"], adjust=False).mean()
        macd  = fast - slow
        sig   = macd.ewm(span=self.cfg["macd_signal"], adjust=False).mean()
        return rsi, ema_f, ema_s, macd, sig

    def get_signal(self, df):
        rsi, ema_f, ema_s, macd, sig = self._indicators(df)

        rsi_buy   = rsi.iloc[-1]   < self.cfg["rsi_oversold"]
        rsi_sell  = rsi.iloc[-1]   > self.cfg["rsi_overbought"]
        ema_buy   = ema_f.iloc[-2] <= ema_s.iloc[-2] and ema_f.iloc[-1] > ema_s.iloc[-1]
        ema_sell  = ema_f.iloc[-2] >= ema_s.iloc[-2] and ema_f.iloc[-1] < ema_s.iloc[-1]
        macd_buy  = macd.iloc[-2]  <= sig.iloc[-2]   and macd.iloc[-1]  > sig.iloc[-1]
        macd_sell = macd.iloc[-2]  >= sig.iloc[-2]   and macd.iloc[-1]  < sig.iloc[-1]

        buy_score  = sum([rsi_buy,  ema_buy,  macd_buy])
        sell_score = sum([rsi_sell, ema_sell, macd_sell])

        log.info(
            "[SIGNAL] RSI=%.1f | EMA %.0f/%.0f | MACD %.1f/Sig %.1f | "
            "Score BUY=%d/3 SELL=%d/3",
            rsi.iloc[-1], ema_f.iloc[-1], ema_s.iloc[-1],
            macd.iloc[-1], sig.iloc[-1], buy_score, sell_score,
        )
        if   buy_score  >= 2: return "BUY"
        elif sell_score >= 2: return "SELL"
        return "NEUTRAL"

    def open(self, signal, mid_price, bid, ask, capital):
        if self.position:
            return

        trade_usdt = capital * self.cfg["trend_trade_pct"]
        if trade_usdt <= 0:
            log.warning("[WARN] Capital insuficiente para operar en tendencia (%.4f)", trade_usdt)
            return

        # 1. Estimar slippage desde el order book
        exec_price, slip_pct, slip_ok = self.client.estimate_slippage(
            self.cfg["symbol"], signal, trade_usdt, self.cfg["max_slippage_pct"]
        )
        if not slip_ok or exec_price <= 0:
            log.warning(
                "[WARN] Slippage excesivo (%.3f%%) -- orden abortada", slip_pct * 100
            )
            return

        # 2. Costes de entrada (taker)
        entry = self.fees.calc_entry_cost(
            trade_usdt, exec_price, "MARKET", slip_pct
        )

        # 3. SL/TP sobre el precio efectivo real
        eff = entry["effective_price"]
        sl  = eff * (1 - self.cfg["sl_pct"]) if signal == "BUY" else eff * (1 + self.cfg["sl_pct"])
        tp  = eff * (1 + self.cfg["tp_pct"]) if signal == "BUY" else eff * (1 - self.cfg["tp_pct"])

        # 4. Avisar si el TP no cubre el breakeven de fees
        min_move = self.fees.min_move_to_profit("MARKET", "MARKET") / 100
        if self.cfg["tp_pct"] <= min_move:
            log.warning(
                "[WARN] TP (%.2f%%) <= breakeven fees (%.3f%%) -- considera aumentar tp_pct",
                self.cfg["tp_pct"] * 100, min_move * 100,
            )

        # 5. Ejecutar orden
        try:
            result = self.client.place_order(
                self.cfg["symbol"], signal, "MARKET", entry["qty"],
                client_oid=f"trend_{signal}_{int(time.time())}",
            )
            self.position = {
                "side":       signal,
                "entry":      eff,
                "qty":        entry["qty"],
                "sl":         round(sl, 2),
                "tp":         round(tp, 2),
                "trade_usdt": trade_usdt,
                "fee_entry":  entry["fee_usdt"],
                "slip_entry": entry["slippage_usdt"],
            }
            self.total_fees_paid += entry["fee_usdt"]
            self.fees.log_summary(signal, entry)
            log.info(
                "[OPEN] [%s] Entry=%.2f | SL=%.2f | TP=%.2f | "
                "Qty=%.6f | ID=%s",
                signal, eff, sl, tp, entry["qty"], result.get("order_id", ""),
            )
        except Exception as exc:
            log.error("[FAIL] Abriendo tendencia: %s", exc)

    def check_exit(self, mid_price):
        """Evalua SL/TP sobre el mid real del ticker."""
        if not self.position:
            return None
        side = self.position["side"]
        if side == "BUY":
            if mid_price <= self.position["sl"]: return "SL"
            if mid_price >= self.position["tp"]: return "TP"
        else:
            if mid_price >= self.position["sl"]: return "SL"
            if mid_price <= self.position["tp"]: return "TP"
        return None

    def close(self, mid_price, bid, ask, reason=""):
        if not self.position:
            return

        close_side = "SELL" if self.position["side"] == "BUY" else "BUY"

        # Slippage de salida (umbral mas permisivo en cierre)
        exit_exec, exit_slip, _ = self.client.estimate_slippage(
            self.cfg["symbol"], close_side,
            self.position["qty"] * mid_price,
            self.cfg["max_slippage_pct"] * 2,
        )
        exit_costs = self.fees.calc_exit_cost(
            self.position["qty"], exit_exec, "MARKET", exit_slip
        )

        entry = self.position["entry"]
        qty   = self.position["qty"]
        if self.position["side"] == "BUY":
            gross = (exit_costs["effective_price"] - entry) * qty
        else:
            gross = (entry - exit_costs["effective_price"]) * qty

        total_fees = self.position["fee_entry"] + exit_costs["fee_usdt"]
        net_pnl    = gross - total_fees
        self.total_fees_paid += exit_costs["fee_usdt"]

        tag = "[OK]" if reason == "TP" else "[FAIL]" if reason == "SL" else "[INFO]"
        try:
            self.client.place_order(
                self.cfg["symbol"], close_side, "MARKET", qty,
            )
            log.info(
                "%s [CLOSE] [%s] Entry=%.2f Exit~%.2f | "
                "PnL bruto=%+.4f Fees=%.4f PnL neto=%+.4f USDT",
                tag, reason, entry, exit_costs["effective_price"],
                gross, total_fees, net_pnl,
            )
            self.fees.log_summary(close_side, exit_costs)
        except Exception as exc:
            log.error("[FAIL] Cerrando tendencia: %s", exc)

        self.position = None

    def unrealized_pnl(self, mid_price):
        if not self.position:
            return 0.0
        pos = self.position
        gross = ((mid_price - pos["entry"]) if pos["side"] == "BUY"
                 else (pos["entry"] - mid_price)) * pos["qty"]
        return round(gross - pos["fee_entry"], 4)


